{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ontology Concept",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "label", "description", "owners", "properties", "mapping"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "synonyms": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "owners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "properties": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["id", "string", "number", "date", "timestamp", "boolean", "enum"]
          },
          "values": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": {
                  "const": "enum"
                }
              }
            },
            "then": {
              "required": ["values"]
            }
          }
        ]
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "target", "cardinality"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "cardinality": {
            "type": "string",
            "enum": ["1", "0..1", "1..n", "0..n"]
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "table", "columns"],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "table": {
          "type": "string",
          "minLength": 1
        },
        "columns": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
